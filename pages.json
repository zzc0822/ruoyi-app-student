{
	"pages": [ //pages数组中第一项表示应用启动页，参考：https://uniapp.dcloud.io/collocation/pages
		/** -----index----- */
		{
			"path": "pages/index/tab",
			"style": {
				"navigationBarTitleText": "campus"
			}
		},
		{
			"path": "pages/index/index",
			"style": {
				"navigationBarTitleText": "首页"
			}
		},
		{
			"path": "pages/index/add",
			"style": {
				"navigationBarTitleText": "发布"
			}
		},
		/** -----me----- */
		{
			"path": "pages/me/me",
			"style": {
				"navigationBarTitleText": "我的"
			}
		},
		{
			"path": "pages/me/setting",
			"style": {
				"navigationBarTitleText": "系统设置"
			}
		},
		/** -----auth----- */
		{
			//扫码小程序登录
			"path": "pages/auth/wxamp",
			"style": {
				"navigationBarTitleText": "用户登录"
			}
		},
		{
			//扫码小程序登录成功
			"path": "pages/auth/wxampSuccess",
			"style": {
				"navigationBarTitleText": "登录成功"
			}
		},
		{
			//扫码小程序登录失败
			"path": "pages/auth/wxampError",
			"style": {
				"navigationBarTitleText": "登录失败"
			}
		},
		/** -----c----- */
		{
			"path": "pages/c/index",
			"style": {
				"navigationBarTitleText": "墙"
			}
		},
		/** -----leave----- */
		{
			"path": "pages/leave/index",
			"style": {
				"navigationBarTitleText": "我的请假",
				"enablePullDownRefresh": false
			}
		},
		/** -----activity----- */
		{
			"path": "pages/activity/index",
			"style": {
				"navigationBarTitleText": "活动报名",
				"enablePullDownRefresh": false
			}
		},
		{
			"path": "pages/activity/detail",
			"style": {
				"navigationBarTitleText": "活动详情",
				"enablePullDownRefresh": false
			}
		},
		{
			"path": "pages/activity/my",
			"style": {
				"navigationBarTitleText": "我的活动",
				"enablePullDownRefresh": false
			}
		},
		/** -----attendance----- */
		{
			"path": "pages/attendance/index",
			"style": {
				"navigationBarTitleText": "出勤与积分",
				"enablePullDownRefresh": true
			}
		}

	],
	"globalStyle": {
		"navigationBarTextStyle": "black",
		"navigationBarTitleText": "uni-app",
		"navigationBarBackgroundColor": "#F8F8F8",
		"backgroundColor": "#F8F8F8"
	},
	"uniIdRouter": {},
	"easycom": {
		"^u-(.*)": "@/uni_modules/uview-ui/components/u-$1/u-$1.vue"
	}
}
